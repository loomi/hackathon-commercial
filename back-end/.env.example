# Application
NODE_ENV=development
PORT=3001

# Swagger UI mount path (served at http://host:port/<SWAGGER_PATH>)
SWAGGER_PATH=docs

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/immersion_db?schema=public

# Used by docker-compose.yml when bringing up the bundled Postgres container.
# Keep them in sync with DATABASE_URL above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=immersion_db
POSTGRES_PORT=5432

# JWT auth
# Replace JWT_ACCESS_SECRET with a long random string in any non-dev environment.
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
